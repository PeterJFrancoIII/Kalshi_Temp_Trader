[Unit]
Description=KMIA System Health Check
# NO REAL TRADING EXECUTION
After=network.target

[Service]
Type=oneshot
User=computer
Group=computer
WorkingDirectory=/opt/kmia-kalshi
ExecStart=/bin/bash /opt/kmia-kalshi/scripts/health_check.sh
Environment="PYTHONPATH=/opt/kmia-kalshi/backend/src"

[Install]
WantedBy=multi-user.target
